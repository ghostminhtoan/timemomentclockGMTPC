<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#1677FF</Color>
    <Color x:Key="PrimaryDark">#74A9FF</Color>
    <Color x:Key="PrimaryDarkText">#EAF2FF</Color>
    <Color x:Key="Secondary">#D7E8FF</Color>
    <Color x:Key="SecondaryDarkText">#BFD8FF</Color>
    <Color x:Key="Tertiary">#0F3D91</Color>
    <Color x:Key="Accent">#34C8A6</Color>
    <Color x:Key="AccentDark">#8EE5D2</Color>
    <Color x:Key="Danger">#FF6B6B</Color>
    <Color x:Key="CardLight">#F7FAFF</Color>
    <Color x:Key="CardDark">#182232</Color>

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Magenta">#00A0A0</Color>
    <Color x:Key="MidnightBlue">#0B1830</Color>
    <Color x:Key="OffBlack">#10151F</Color>

    <Color x:Key="Gray100">#F1F5FA</Color>
    <Color x:Key="Gray200">#D5DCE7</Color>
    <Color x:Key="Gray300">#B3BDCC</Color>
    <Color x:Key="Gray400">#8794A8</Color>
    <Color x:Key="Gray500">#66758A</Color>
    <Color x:Key="Gray600">#495568</Color>
    <Color x:Key="Gray900">#1D2737</Color>
    <Color x:Key="Gray950">#0E1520</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}" />
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}" />
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}" />
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}" />
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" />
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}" />
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}" />
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}" />
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}" />
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}" />
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}" />
</ResourceDictionary>
