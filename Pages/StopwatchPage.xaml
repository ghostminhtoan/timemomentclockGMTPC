<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Time_Moment_Clock_GMTPC.Pages.StopwatchPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="StopwatchRoot"
    Title="Stopwatch">

    <ScrollView>
        <VerticalStackLayout Padding="20,20,20,32" Spacing="18">
            <Border Padding="24">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Stopwatch" Style="{StaticResource MutedLabel}" />
                    <Label Text="{Binding ElapsedTime}" Style="{StaticResource HeroTitleLabel}" />
                    <Label Text="Tap lap de danh dau tung vong." Style="{StaticResource MutedLabel}" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="20">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Dieu khien" Style="{StaticResource SectionTitleLabel}" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                        <Button Grid.Row="0" Text="{Binding StartPauseText}" Command="{Binding StartPauseCommand}" />
                        <Button Grid.Row="0" Grid.Column="1" Text="Lap" Command="{Binding AddLapCommand}" />
                        <Button Grid.Row="1" Text="Reset" Command="{Binding ResetCommand}" />
                        <Button Grid.Row="1" Grid.Column="1" Text="{Binding FloatingActionText}" Command="{Binding ToggleFloatingModeCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Padding="20">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Danh sach lap" Style="{StaticResource SectionTitleLabel}" />
                    <CollectionView ItemsSource="{Binding Laps}" HeightRequest="260" EmptyView="Chua co lap nao.">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14" Margin="0,0,0,10">
                                    <Label Text="{Binding .}" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
