<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Time_Moment_Clock_GMTPC.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:Time_Moment_Clock_GMTPC.Pages"
    Title="Time Moment Clock">

    <TabBar>
        <ShellContent
            Title="Clock"
            Route="clock"
            ContentTemplate="{DataTemplate pages:ClockPage}" />
        <ShellContent
            Title="Stopwatch"
            Route="stopwatch"
            ContentTemplate="{DataTemplate pages:StopwatchPage}" />
        <ShellContent
            Title="Countdown"
            Route="countdown"
            ContentTemplate="{DataTemplate pages:CountdownPage}" />
        <ShellContent
            Title="Alarm"
            Route="alarm"
            ContentTemplate="{DataTemplate pages:AlarmPage}" />
    </TabBar>

</Shell>
